# Database Configuration (Render will set these automatically)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/itaccess
SPRING_DATASOURCE_DRIVER_CLASS=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=itaccess_user
SPRING_DATASOURCE_PASSWORD=your_password_here

# Hibernate Dialect (set to PostgreSQL for production)
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# H2 Console (disable in production)
H2_CONSOLE_ENABLED=false

# Server Configuration
SERVER_PORT=8000

# CORS Configuration (add your frontend URL in production)
CORS_ALLOWED_ORIGINS=https://your-frontend-url.com

# JWT Secret (Render will generate this automatically)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long

# Logging Level
LOG_LEVEL=INFO
